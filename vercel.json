{
  "redirects": [
    { "source": "/app.html", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/radca/:slug.html", "destination": "/poradna/:slug", "permanent": true },
    { "source": "/radca/:slug", "destination": "/poradna/:slug", "permanent": true },
    { "source": "/radca", "destination": "/poradna", "permanent": true },
    { "source": "/poradna/:slug.html", "destination": "/poradna/:slug", "permanent": true }
  ],
  "rewrites": [
    { "source": "/poradna/:slug", "destination": "/poradna/:slug.html" }
  ]
}
